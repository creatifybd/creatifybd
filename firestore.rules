rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && (
          request.auth.token.admin == true
          || request.auth.token.email == "binashad7@gmail.com"
        );
    }

    function isValidMessage() {
      return request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() <= 180
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 3000
        && request.resource.data.status == "unread"
        && request.resource.data.read == false;
    }

    match /messages/{message} {
      allow create: if isValidMessage();
      allow read, update, delete: if isAdmin();
    }
    match /services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /portfolio/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /testimonials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pricing/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /case_study_images/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /case_studies/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Manual Payments Collection
    function isValidPayment() {
      return request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.phone is string
        && request.resource.data.selectedService is string
        && request.resource.data.paymentMethod is string
        && request.resource.data.paidAmount is string
        && request.resource.data.transactionId is string
        && request.resource.data.proofFileUrl is string
        && request.resource.data.status == "pending"
        && request.resource.data.createdAt is timestamp;
    }

    match /manualPayments/{paymentId} {
      allow create: if isValidPayment();
      allow read: if isAdmin();
      allow update: if isAdmin()
        && (request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'adminNote', 'verifiedBy', 'verifiedAt', 'rejectedBy', 'rejectedAt', 'updatedAt']));
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
